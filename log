bool HeaderTable::_keysMatch(const s_view& k1, const s_view& k2) const {
	if (k1.len != k2.len || k1.Data == NULL || k2.Data == NULL)
		return false;
	return (std::memcmp(k1.Data, k2.Data, k1.len) == 0);
}


